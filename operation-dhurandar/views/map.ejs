<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- Leaflet (real interactive map) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
  #india-map { height: 540px; border-radius: 12px; background: #04100a; }
  #india-map .leaflet-tile { filter: hue-rotate(80deg) saturate(0.7) brightness(0.75); }
  .leaflet-container { font-family: 'Share Tech Mono', monospace; background: #04100a; }
  .leaflet-popup-content-wrapper, .leaflet-popup-tip {
    background: rgba(10,20,16,.95); color: #d1fae5; border: 1px solid rgba(63,255,159,.4);
    box-shadow: 0 0 24px rgba(63,255,159,.25);
  }
  .leaflet-popup-content { margin: 12px 14px; }
  .leaflet-control-zoom a { background: rgba(10,20,16,.9); color: #3fff9f; border-color: rgba(63,255,159,.3); }
  .leaflet-control-attribution { background: rgba(0,0,0,.5) !important; color: #4d6b5c !important; }
  .leaflet-control-attribution a { color: #3fff9f !important; }
  /* glowing pin */
  .lpin { transform: translate(-50%, -100%); text-align: center; }
  .lpin-dot { display:block; width:16px; height:16px; border-radius:50%; margin:0 auto; position:relative; }
  .lpin-dot::after { content:''; position:absolute; inset:-6px; border-radius:50%; border:1px solid currentColor; animation: ping 1.8s ease-out infinite; }
  .lpin-label { display:block; margin-top:4px; font-size:.6rem; letter-spacing:.08em; white-space:nowrap; text-shadow:0 0 8px currentColor; }
  /* radar sweep overlay on the map */
  .map-sweep { position:absolute; left:50%; top:50%; width:150%; height:150%; transform:translate(-50%,-50%);
    border-radius:50%; pointer-events:none; z-index:450; mix-blend-mode:screen;
    background: conic-gradient(from 0deg, rgba(63,255,159,.14), transparent 22%); animation: sweep 7s linear infinite; }
</style>

<main class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div>
      <h1 class="font-head font-black tracking-widest text-2xl text-mil-green glow-text">SECTOR MAP — INDIA</h1>
      <p class="font-mono text-xs text-emerald-400/60" data-decrypt="OFFICER PLACEMENT GRID">OFFICER PLACEMENT GRID</p>
    </div>
    <span class="chip chip-danger"><i data-lucide="triangle-alert" class="w-3 h-3"></i> STYLIZED · FICTIONAL PLACEMENTS</span>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- map -->
    <div class="lg:col-span-2 glass hud-frame p-4 reveal">
      <div class="relative">
        <div id="india-map"></div>
        <div class="map-sweep"></div>
      </div>
      <p class="font-mono text-[11px] text-emerald-400/40 text-center mt-3">▶ Click a glowing pin to decrypt the officer's placement</p>
    </div>

    <!-- sector intel panel -->
    <div class="glass hud-frame p-6 reveal">
      <div id="sector-panel" class="opacity-0 transition-opacity duration-500">
        <p class="font-mono text-sm text-emerald-400/50">Select a placement pin to view classified posting information.</p>
      </div>
      <div class="mt-6 pt-5 border-t border-mil-green/15">
        <h3 class="font-mono text-xs text-emerald-400/60 mb-2">DEPLOYED OFFICERS</h3>
        <div class="space-y-1">
          <% Object.keys(members).forEach(function(name){ var m=members[name]; %>
            <button onclick="focusOfficer('<%= name %>')" class="w-full flex items-center justify-between px-3 py-2 rounded lb-row text-left">
              <span class="font-mono text-sm"><span style="color:<%= m.accent %>">●</span> <%= name %></span>
              <span class="font-mono text-[11px] text-emerald-400/60"><%= m.posting %></span>
            </button>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  // ----- officer data + computed India coordinates -----
  // sector.x/y (0-100) map onto India's bounding box (lng 68->97, lat 37->8).
  // This keeps placements clearly fictional/regional, not real sensitive sites.
  window.SECTORS = {};
  var OFFICERS = [
    <% Object.keys(members).forEach(function(name){ var m=members[name];
       var lng = 68 + (m.sector.x/100)*(97-68);
       var lat = 37 - (m.sector.y/100)*(37-8); %>
    {
      username: '<%= name %>',
      posting: '<%= m.posting %>',
      rank: '<%= m.rank %>',
      callsign: '<%= m.callsign %>',
      clearance: '<%= m.clearance %>',
      status: '<%= m.status %>',
      accent: '<%= m.accent %>',
      lat: <%= lat.toFixed(3) %>,
      lng: <%= lng.toFixed(3) %>
    },
    <% }) %>
  ];
  OFFICERS.forEach(function(o){ window.SECTORS[o.username] = o; });

  // ----- init Leaflet map over India -----
  var map = L.map('india-map', {
    center: [23, 82], zoom: 4.4, minZoom: 4, maxZoom: 7,
    scrollWheelZoom: false, zoomControl: true,
    maxBounds: [[5, 66], [38, 99]], maxBoundsViscosity: 0.8
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: 'Map © OpenStreetMap, © CARTO · Fictional demo',
    subdomains: 'abcd', maxZoom: 7
  }).addTo(map);

  var markers = {};
  OFFICERS.forEach(function(o){
    var icon = L.divIcon({
      className: '',
      iconSize: [0,0],
      html: '<div class="lpin" style="color:'+o.accent+'">'
          + '<span class="lpin-dot" style="background:'+o.accent+';box-shadow:0 0 14px '+o.accent+'"></span>'
          + '<span class="lpin-label">'+o.posting+'</span></div>'
    });
    var mk = L.marker([o.lat, o.lng], { icon: icon }).addTo(map);
    mk.on('click', function(){ openSector(o.username); });
    markers[o.username] = mk;
  });

  // focus + open intel when picking an officer from the side list
  window.focusOfficer = function(name){
    var o = window.SECTORS[name];
    if (!o) return;
    map.flyTo([o.lat, o.lng], 5.5, { duration: 0.8 });
    if (markers[name]) markers[name].openPopup && markers[name].openPopup();
    openSector(name);
  };
</script>

<%- include('partials/footer') %>
