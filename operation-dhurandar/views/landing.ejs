<%- include('partials/head') %>
<%- include('partials/loader') %>
<%- include('partials/nav') %>

<!-- ============================== HERO ============================== -->
<header class="relative max-w-7xl mx-auto px-4 pt-16 pb-12">
  <div class="grid lg:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <span class="chip chip-danger mb-5"><i data-lucide="lock" class="w-3 h-3"></i> CLASSIFIED // LEVEL ALPHA</span>
      <h1 class="font-head font-black tracking-tight text-5xl md:text-7xl leading-none text-mil-green glow-text">
        OPERATION<br />DHURANDAR
      </h1>
      <p class="font-mono text-emerald-300/80 mt-5 text-lg" data-typewriter="Classified Military Personnel Portal">Classified Military Personnel Portal</p>
      <p class="text-emerald-100/60 mt-4 max-w-md leading-relaxed">
        Encrypted access to operative dossiers, live sector telemetry and mission
        scoring. Authorisation required beyond this point.
      </p>
      <div class="flex flex-wrap gap-3 mt-8">
        <a href="/login" class="btn-primary"><i data-lucide="log-in" class="w-4 h-4"></i> ACCESS PORTAL</a>
        <a href="#brief" class="btn-ghost"><i data-lucide="file-text" class="w-4 h-4"></i> MISSION BRIEF</a>
      </div>
    </div>

    <!-- radar console -->
    <div class="reveal">
      <div class="glass hud-frame p-6">
        <div class="flex items-center justify-between mb-4 font-mono text-xs text-emerald-400/60">
          <span>SECTOR RADAR · LIVE</span><span class="flex items-center gap-2"><span class="status-dot"></span>TRACKING</span>
        </div>
        <div class="radar mx-auto max-w-xs">
          <div class="radar-cross"></div>
          <% const seed=[[30,35],[68,28],[42,70],[72,62]]; seed.forEach(function(p){ %>
            <div class="radar-blip" style="left:<%= p[0] %>%; top:<%= p[1] %>%"></div>
          <% }) %>
        </div>
        <div class="grid grid-cols-3 gap-2 mt-5 font-mono text-center">
          <div class="glass p-3"><div class="text-2xl text-mil-green glow-text"><%= Object.keys(members).length %></div><div class="text-[10px] text-emerald-400/60">OFFICERS</div></div>
          <div class="glass p-3"><div class="text-2xl text-mil-amber"><%= leaderboard.reduce(function(a,r){return a+r.points},0) %></div><div class="text-[10px] text-emerald-400/60">TOTAL XP</div></div>
          <div class="glass p-3"><div class="text-2xl text-mil-cyan">04</div><div class="text-[10px] text-emerald-400/60">SECTORS</div></div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- ====================== CURRENT MISSION ====================== -->
<section id="brief" class="max-w-7xl mx-auto px-4 py-10">
  <div class="glass hud-frame p-8 reveal">
    <div class="flex items-center gap-3 mb-3">
      <i data-lucide="crosshair" class="text-mil-amber"></i>
      <h2 class="font-head tracking-widest text-mil-amber text-xl">CURRENT MISSION</h2>
    </div>
    <p class="font-mono text-emerald-100/80 leading-relaxed max-w-3xl">
      <span class="amber-text">OBJECTIVE:</span> Coordinate the four-officer task force across Northern,
      Eastern, Western and Training commands. Maintain operational tempo, log field actions, and keep the
      unit at peak readiness. <span class="text-emerald-400/50">// All operations strictly fictional.</span>
    </p>
  </div>
</section>

<!-- ====================== LEADERBOARD PREVIEW ====================== -->
<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between mb-5">
    <h2 class="font-head tracking-widest text-mil-green text-xl flex items-center gap-2"><i data-lucide="trophy"></i> LEADERBOARD</h2>
    <a href="/login" class="font-mono text-xs text-emerald-400/60 hover:text-mil-green">FULL RANKINGS →</a>
  </div>
  <div class="glass p-3 reveal">
    <% leaderboard.forEach(function(r, i){ %>
      <div class="lb-row flex items-center justify-between px-4 py-3 rounded <%= i<3 ? 'rank-'+(i+1) : '' %>">
        <div class="flex items-center gap-4">
          <span class="font-head text-lg w-8 <%= i===0?'medal-gold':i===1?'medal-silver':i===2?'medal-bronze':'text-emerald-400/50' %>"><%= i<3 ? ['🥇','🥈','🥉'][i] : '#'+(i+1) %></span>
          <div>
            <div class="font-semibold text-emerald-100"><%= r.username %></div>
            <div class="font-mono text-[11px] text-emerald-400/60 uppercase"><%= r.militaryRank %></div>
          </div>
        </div>
        <div class="text-right">
          <div class="font-mono text-mil-green text-lg"><%= r.points %> <span class="text-xs text-emerald-400/50">XP</span></div>
          <div class="font-mono text-[10px] text-emerald-400/50">LVL <%= r.level %></div>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<!-- ============================ FEATURES ============================ -->
<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <% const feats=[['radar','Sector Radar','Live posting telemetry'],['shield-check','Encrypted Auth','Session-secured access'],['award','Mission XP','Score field actions'],['map','Tactical Map','Officer deployment grid']]; feats.forEach(function(f){ %>
      <div class="glass card-hover p-6 reveal">
        <span class="emblem mb-4"><i data-lucide="<%= f[0] %>"></i></span>
        <h3 class="font-head tracking-wide text-mil-green"><%= f[1] %></h3>
        <p class="text-emerald-100/60 text-sm mt-1"><%= f[2] %></p>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
